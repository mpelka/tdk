urgent — other problem, ticket MOCKED (mock wins over the simulator):
  steps:
    ticket-title:
      input:
        data:
          bakeryCode: BK1
          ovenId: OV-4471
          severity: urgent
        expression: '((((severity = "urgent") ? "[URGENT] " : "")) & "Oven " & (ovenId)
          & " at " & (bakeryCode))'
      output:
        result: "[URGENT] Oven OV-4471 at BK1"
    sla-hours:
      input:
        data:
          severity: urgent
        expression: |-
          ((severity = "urgent")
            ? 4
            : ((severity = "normal") ? 24 : 72))
      output:
        result: 4
    problem-summary:
      input:
        data:
          problemArea: other
          otherDetail: Door seal warped, heat escaping
        expression: |-
          ((problemArea = "other")
            ? ($boolean(otherDetail) ? otherDetail : "unspecified")
            : problemArea)
      output:
        result: Door seal warped, heat escaping
    open-oven-ticket:
      input:
        title: "[URGENT] Oven OV-4471 at BK1"
        slaHours: 4
        summary: Door seal warped, heat escaping
        site: BK1
        oven: OV-4471
        ovenType: deck
        urgentReason: Production line stopped
        contact: baker@riverside.example
      output:
        body:
          id: TCK-8801
          url: https://catalog.example/tickets/8801
  output:
    ticketUrl: https://catalog.example/tickets/8801
    ticketId: TCK-8801
