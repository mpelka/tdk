urgent — other problem with detail, rush SLA:
  steps:
    ticket-title:
      input:
        data:
          bakeryCode: BK1
          ovenId: OV-4471
          severity: urgent
        expression: '((((severity = "urgent") ? "[URGENT] " : "")) & "Oven " & (ovenId)
          & " at " & (bakeryCode))'
      output:
        result: "[URGENT] Oven OV-4471 at BK1"
    sla-hours:
      input:
        data:
          severity: urgent
        expression: |-
          ((severity = "urgent")
            ? 4
            : ((severity = "normal") ? 24 : 72))
      output:
        result: 4
    problem-summary:
      input:
        data:
          problemArea: other
          otherDetail: Door seal warped, heat escaping
        expression: |-
          ((problemArea = "other")
            ? ($boolean(otherDetail) ? otherDetail : "unspecified")
            : problemArea)
      output:
        result: Door seal warped, heat escaping
    audit-tag:
      input:
        data:
          bakeryCode: BK1
          severity: urgent
        expression: ((bakeryCode) & ":" & (severity))
      output:
        result: BK1:urgent
    oven-lookup:
      input:
        asset: OV-4471
      output:
        model: Rondo Deck 3
        installedYear: 2019
    oven-context:
      input:
        data:
          model: Rondo Deck 3
          installedYear: 2019
        expression: ((model) & " (installed " & (installedYear) & ")")
      output:
        result: Rondo Deck 3 (installed 2019)
    register:
      input:
        title: "[URGENT] Oven OV-4471 at BK1"
        slaHours: 4
        summary: Door seal warped, heat escaping
        oven: Rondo Deck 3 (installed 2019)
        site: BK1
      output:
        ticketId: TCK-8801
        url: https://catalog.example/tickets/8801
  output:
    title: "[URGENT] Oven OV-4471 at BK1"
    slaHours: 4
    ticketId: TCK-8801
    audit: BK1:urgent
