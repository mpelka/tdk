      "http:backstage:request": {
        "input": {
          "path": "/api/bakery/assignment"
        },
        "output": {
          "name": "north-riverside-bakery"
        }
      },
      "debug:log": {
        "input": {
          "slot": "9am-slot",
          "recipient": "BAKER SAM",
          "banner": "Delivery slot — urgency 4",
          "tier": "URGENT",
          "region": "north"
        }
      }
    }
  },
  "null slot + missing contact — both fall back": {
    "effects": {
      "http:backstage:request": {
        "input": {
          "path": "/api/bakery/assignment"
        },
        "output": {
          "name": "west-park-bakery"
        }
      },
      "debug:log": {
        "input": {
          "slot": "next-available",
          "recipient": "WEST-PARK-BAKERY",
          "banner": "Delivery slot — urgency 2",
          "tier": "standard",
          "region": "west"
        }
      }
    }
  },
  "absent slot — fallback (same as null)": {
    "effects": {
      "http:backstage:request": {
        "input": {
          "path": "/api/bakery/assignment"
        },
        "output": {
