publish with a long headline:
  steps:
    publish:
      input:
        featuredFlavour: vanilla
        headline: Our seasonal vanilla is back — pre-order now for the weekend rush
        cluster: test-oven
      output:
        url: https://storefront.example/menu
  output:
    featured: vanilla
