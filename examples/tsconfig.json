{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["bun"]
  },
  "include": [
    "payload-oracle.ts",
    "conditional-forms",
    "payload-assembly",
    "fallback-chains",
    "env-loaded",
    "api-loaded",
    "plugin-composed",
    "oven-support",
    "oven-support-v2"
  ]
}
