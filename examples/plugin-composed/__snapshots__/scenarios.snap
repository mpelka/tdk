provision a pastry oven:
  steps:
    provision:
      input:
        station: pastry
        capacity: 12
        model: deck-3000
      output:
        ovenId: oven-pastry-12
        endpoint: https://ovens.example/pastry/12
        ready: true
    record:
      input:
        headBaker: baker-pastry-01
        ovenId: oven-pastry-12
  output:
    station: pastry
    ovenModel: deck-3000
